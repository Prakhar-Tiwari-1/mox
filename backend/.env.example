MOX_BACKEND_SECRET_KEY=replace-with-a-long-random-secret
MOX_BACKEND_DEBUG=0
MOX_BACKEND_ALLOWED_HOSTS=localhost,127.0.0.1,moxpolytechnique.com,www.moxpolytechnique.com
MOX_FRONTEND_ORIGINS=http://localhost:5173,https://moxpolytechnique.com,https://www.moxpolytechnique.com
MOX_FRONTEND_SITE_URL=http://localhost:5173

MOX_BACKEND_DB_ENGINE=django.db.backends.sqlite3
MOX_BACKEND_DB_NAME=./db.sqlite3
MOX_BACKEND_DB_USER=
MOX_BACKEND_DB_PASSWORD=
MOX_BACKEND_DB_HOST=
MOX_BACKEND_DB_PORT=

MOX_EMAIL_HOST=smtp.resend.com
MOX_EMAIL_PORT=587
MOX_EMAIL_USE_TLS=1
MOX_EMAIL_HOST_USER=resend
MOX_EMAIL_HOST_PASSWORD=replace-with-your-resend-api-key
MOX_DEFAULT_FROM_EMAIL=MoX <mox@polytechnique.fr>
MOX_CONTACT_REPLY_TO=mox@polytechnique.fr
MOX_CONTACT_RATE_LIMIT=5/hour
MOX_MAX_UPLOAD_SIZE_BYTES=5242880
MOX_SECURE_SSL_REDIRECT=1
MOX_ENABLE_HSTS=1
MOX_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
MOX_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
MOX_ADMIN_IP_ALLOWLIST=
MOX_ADMIN_SESSION_TIMEOUT_SECONDS=1800
